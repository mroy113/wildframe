{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "wildframe",
  "version-string": "0.0.0",
  "description": "Bird photo culling assistant. Detects birds in CR3 RAW files, scores focus/keeper quality, and writes XMP sidecar metadata.",
  "license": null,
  "supports": "osx",
  "builtin-baseline": "c3867e714dd3a51c272826eea77267876517ed99",
  "dependencies": [
    "libraw",
    "exiv2",
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "jpeg",
        "png"
      ]
    },
    "onnxruntime",
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "gui",
        "widgets"
      ]
    },
    "nlohmann-json",
    "tomlplusplus",
    "spdlog",
    "gtest"
  ],
  "overrides": [
    {
      "name": "libraw",
      "version": "0.22.0"
    },
    {
      "name": "exiv2",
      "version": "0.28.8"
    },
    {
      "name": "opencv4",
      "version": "4.12.0",
      "port-version": 1
    },
    {
      "name": "onnxruntime",
      "version-semver": "1.23.2"
    },
    {
      "name": "qtbase",
      "version": "6.10.2"
    },
    {
      "name": "nlohmann-json",
      "version": "3.12.0",
      "port-version": 2
    },
    {
      "name": "tomlplusplus",
      "version": "3.4.0",
      "port-version": 1
    },
    {
      "name": "spdlog",
      "version-semver": "1.17.0"
    },
    {
      "name": "gtest",
      "version-semver": "1.17.0",
      "port-version": 2
    }
  ]
}
